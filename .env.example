# 환경변수 템플릿 (값은 비워둠). 실제 값은 .env(로컬) 또는 배포 시크릿에 설정.
# 실제 키는 절대 이 파일이나 .env 를 통해 커밋하지 마세요.

# --- Supabase (Lovable Cloud 연결 시 자동 주입) ---
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- AI ---
LOVABLE_API_KEY=          # Lovable AI 게이트웨이 (GPT/Gemini 라우팅)
GEMINI_API_KEY=           # 내 구글 Gemini 키 직접 호출(선택)

# --- 오픈마켓 / 자동화 ---
ELEVENST_API_KEY=         # 11번가 오픈 API
ELEVENST_DRY_RUN=         # true 면 11번가 실제 등록 대신 payload 검증만
TOSS_ACCESS_KEY=
TOSS_SECRET_KEY=
CRON_SECRET=              # 설정 시 공개 훅 호출에 x-cron-secret 헤더 요구
